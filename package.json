{
  "name": "pb-extensions",
  "author": "TiDev00",
  "license": "MIT",
  "version": "1.0.0",
  "packageManager": "pnpm@8.8.0",
  "repositoryName": "pb-extensions",
  "description": "Paperback v0.8 extension repository",
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs'),path=require('path');try{fs.readdirSync('src').forEach(s=>{const base=path.join('src',s,'includes'),jpg=path.join(base,'icon.jpg'),png=path.join(base,'icon.png');if(fs.existsSync(jpg)&&!fs.existsSync(png)){fs.copyFileSync(jpg,png);fs.unlinkSync(jpg);console.log('[prebuild] converted '+jpg+' -> '+png)}})}catch(e){}\"",
    "build": "paperback bundle",
    "serve": "paperback serve",
    "lint": "eslint --ext .ts src/",
    "test": "pnpm run build && node tests/SourceTester.js",
    "test:local": "LOCAL_DEV=1 node tests/SourceTester.js"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@paperback/toolchain": "^0.8.7",
    "@paperback/types": "^0.8.7",
    "cheerio": "^1.0.0-rc.12"
  }
}
